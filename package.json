{
  "name": "my-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "generate": "turbo generate",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:api": "turbo dev --filter=@repo/api",
    "dev:web": "turbo dev --filter=@repo/web",
    "db:generate": "turbo generate --filter=@repo/api",
    "db:migrate": "turbo migrate:dev --filter=@repo/api",
    "db:studio": "turbo db:studio --filter=@repo/api",
    "db:seed": "turbo db:seed --filter=@repo/api",
    "build:api": "turbo build --filter=@repo/api",
    "build:web": "turbo build --filter=@repo/web",
    "lint:api": "turbo lint --filter=@repo/api",
    "lint:web": "turbo lint --filter=@repo/web"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
